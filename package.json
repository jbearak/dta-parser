{
  "name": "@jbearak/dta-parser",
  "version": "0.1.0",
  "description": "TypeScript parser for Stata .dta files",
  "type": "module",
  "license": "GPL-3.0",
  "author": "Jonathan Marc Bearak",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbearak/dta-parser.git"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "typesVersions": {
    "*": {
      "node": [
        "dist/types/node.d.ts"
      ],
      "*": [
        "dist/types/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./node": {
      "types": "./dist/types/node.d.ts",
      "import": "./dist/esm/node.js",
      "require": "./dist/cjs/node.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:types": "tsc -p tsconfig.types.json",
    "build:esm": "esbuild src/index.ts src/node.ts --bundle --platform=node --target=node20 --format=esm --outdir=dist/esm --outbase=src",
    "build:cjs": "esbuild src/index.ts src/node.ts --bundle --platform=node --target=node20 --format=cjs --outdir=dist/cjs --outbase=src --out-extension:.js=.cjs",
    "build": "npm run clean && npm run build:types && npm run build:esm && npm run build:cjs",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.types.json --noEmit",
    "test": "bun test ./tests"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.5",
    "esbuild": "^0.27.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
